<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="AutoCompleteBox.Filled">
    <Setter Property="Theme" Value="{StaticResource MaterialFilledAutoCompleteBox}" />
  </Style>

  <Style Selector="AutoCompleteBox.Outline">
    <Setter Property="Theme" Value="{StaticResource MaterialOutlineAutoCompleteBox}" />
  </Style>

  <Style Selector="AutoCompleteBox.filled">
    <Setter Property="Theme" Value="{StaticResource MaterialFilledAutoCompleteBox}" />
  </Style>

  <Style Selector="AutoCompleteBox.outline">
    <Setter Property="Theme" Value="{StaticResource MaterialOutlineAutoCompleteBox}" />
  </Style>
</Styles>